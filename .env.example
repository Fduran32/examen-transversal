# Copia este archivo como ".env" (sin el ".example") y completa tus propios valores.
# El archivo ".env" real NUNCA debe subirse a git (agrégalo a .gitignore).

# Contraseña de la base de datos MySQL (root)
DB_PASSWORD=changeme123

# Clave secreta compartida para firmar/validar JWT entre los 3 microservicios
# Debe ser la MISMA en usuarios-service, productos-service y carrito-service
JWT_SECRET=EstaEsUnaClaveSuperSecretaParaExpressNow2024

# Credenciales de AWS para carrito-service (integración con SQS)
AWS_ACCESS_KEY_ID=tu_access_key_aqui
AWS_SECRET_ACCESS_KEY=tu_secret_key_aqui
